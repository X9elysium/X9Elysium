# Cloudflare Workers Static Assets — _headers
# Applied to every static response served from `out/`. Worker /api/* routes
# set their own headers in worker/index.ts. Format reference:
# https://developers.cloudflare.com/workers/static-assets/headers/

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  Cross-Origin-Opener-Policy: same-origin
  X-DNS-Prefetch-Control: on

# Long-cache the immutable Next build chunks (filename is content-hashed).
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache static images, fonts.
/images/*
  Cache-Control: public, max-age=2592000

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
